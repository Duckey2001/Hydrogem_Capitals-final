# ======================================
# Hydrogem Capitals - Admin Portal
# Environment Configuration
# ======================================

# Database Configuration (MongoDB - admin accounts)
DB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hydrogem_capitals?retryWrites=true&w=majority
DB_NAME=hydrogem_capitals
DB_USER=admin_user
DB_PASSWORD=your_secure_db_password_here

# PostgreSQL Configuration (user accounts - js/backenddb.js)
# Either set DATABASE_URL, or the individual PG_* values below.
DATABASE_URL=
PG_USER=your_db_user
PG_HOST=localhost
PG_DATABASE=postgres
PG_PASSWORD=your_db_password
PG_PORT=5432

# Frontend API base URL (leave blank to use same origin as the served pages)
REACT_APP_API_BASE=

# Security Configuration
JWT_SECRET=your_very_strong_jwt_secret_key_32+_characters_long
SESSION_SECRET=another_strong_secret_for_sessions_32+_chars
CSRF_SECRET=csrf_protection_secret_key_32+_chars
PEPPER_KEY=additional_password_pepper_32_chars

# Server Configuration
PORT=3000
NODE_ENV=production
HOSTNAME=admin.hydrogemcapitals.com
HTTPS_PORT=443

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW=15 # minutes
LOGIN_RATE_LIMIT_MAX=5 # attempts per window

# Session Configuration
SESSION_MAX_AGE=3600000 # 1 hour in ms
COOKIE_DOMAIN=.hydrogemcapitals.com

# Email Configuration (for password recovery)
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=admin@hydrogemcapitals.com
SMTP_PASSWORD=email_account_password
ADMIN_EMAIL=admin@hydrogemcapitals.com

# Security Headers
CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline' cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' cdnjs.cloudflare.com; img-src 'self' data:; font-src 'self' cdnjs.cloudflare.com; connect-src 'self'"
HSTS_MAX_AGE=31536000 # 1 year
