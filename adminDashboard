<!-- Password Generator--> 

<script>

function generatePassword() {
  var passwordField = document.getElementById('password');
  var generatePasswordCheckbox = document.getElementById('generate_password');

  if (generatePasswordCheckbox.checked) {
    passwordField.value = Math.random().toString(36).slice(-8); // Generates a random 8-character password
  } else {
    passwordField.value = ''; // Clears the password field if the checkbox is unchecked
  }
}
</script>
